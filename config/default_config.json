{
  "conexion": {
    "puerto": "SIMULADOR",
    "baudrate": 115200,
    "bits_datos": 8,
    "paridad": "N",
    "bits_parada": 1,
    "timeout": 1.0,
    "delay_conexion": 10,
    "intervalo_polling_ms": 50
  },
  "sensores": {
    "fuerza": {
      "nombre": "Fuerza",
      "unidad": "N",
      "offset_payload": 1,
      "escala": 0.5,
      "offset_valor": 0.0,
      "min_rango": 0,
      "max_rango": 3000
    },
    "recorrido": {
      "nombre": "Recorrido",
      "unidad": "mm",
      "offset_payload": 2,
      "escala": 0.392157,
      "offset_valor": 0.0,
      "min_rango": 0,
      "max_rango": 100
    },
    "temp_amortiguador": {
      "nombre": "Temp Amortiguador",
      "unidad": "°C",
      "offset_payload": 3,
      "escala": 1.0,
      "offset_valor": -40.0,
      "min_rango": -40,
      "max_rango": 215
    },
    "temp_reservorio": {
      "nombre": "Temp Reservorio",
      "unidad": "°C",
      "offset_payload": 4,
      "escala": 1.0,
      "offset_valor": -40.0,
      "min_rango": -40,
      "max_rango": 215
    },
    "velocidad": {
      "nombre": "Velocidad",
      "unidad": "RPM",
      "offset_payload_high": 5,
      "offset_payload_low": 6,
      "escala": 1.0,
      "offset_valor": 0.0,
      "min_rango": 0,
      "max_rango": 9999
    }
  },
  "alarmas": {
    "temp_amortiguador_max": 60.0,
    "temp_reservorio_max": 50.0,
    "fuerza_max": 2000.0,
    "velocidad_max": 5000.0,
    "sonido_habilitado": true
  },
  "logging": {
    "habilitado": true,
    "carpeta": "logs",
    "prefijo_archivo": "shock_test",
    "incluir_timestamp_ms": true,
    "separador": ","
  },
  "ui": {
    "tema": "oscuro",
    "actualizacion_ms": 50,
    "buffer_graficas_segundos": 30,
    "mostrar_estadisticas": true,
    "ventana_ancho": 1200,
    "ventana_alto": 800
  },
  "simulador": {
    "fuerza_min": 100.0,
    "fuerza_max": 1500.0,
    "recorrido_min": 10.0,
    "recorrido_max": 80.0,
    "temp_amortiguador_min": 25.0,
    "temp_amortiguador_max": 55.0,
    "temp_reservorio_min": 20.0,
    "temp_reservorio_max": 50.0,
    "velocidad_min": 50.0,
    "velocidad_max": 400.0
  }
}
